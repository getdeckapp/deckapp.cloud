---
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '0x4AAAAAADVDrZpOGEt_2lnP';
---

<section id="waitlist" class="relative overflow-hidden py-20">
	<div
		class="absolute inset-0 -z-10"
		style="background: radial-gradient(60% 80% at 50% 0%, rgba(245,158,11,0.16) 0%, transparent 70%)"
	>
	</div>
	<div class="mx-auto max-w-[900px] px-6">
		<div
			class="relative overflow-hidden rounded-3xl border border-zinc-200/70 bg-gradient-to-br from-zinc-950 via-zinc-900 to-zinc-950 px-8 py-14 sm:px-14 shadow-[0_24px_60px_-16px_rgba(15,23,42,0.40),0_0_0_1px_rgba(15,23,42,0.10)]"
		>
			<div class="relative max-w-[640px]">
				<h2 class="text-[38px] font-semibold tracking-[-0.025em] text-white leading-[1.1] sm:text-[46px]">
					Your queues already<br />have a memory.<br />
					<span class="bg-gradient-to-r from-amber-300 to-orange-300 bg-clip-text text-transparent"
						>Stop forgetting.</span
					>
				</h2>
				<p class="mt-5 max-w-[480px] text-[15px] leading-[1.65] text-zinc-300">
					Deck Cloud is in early access. Leave your email and you'll be among the first to know when it
					opens — plus you lock in the launch pricing.
				</p>

				<div id="waitlist-success" class="mt-8 hidden items-center gap-3 rounded-xl bg-emerald-500/15 px-5 py-4 ring-1 ring-inset ring-emerald-400/30">
					<span class="inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">✓</span>
					<div>
						<p class="text-[14px] font-semibold text-emerald-300">You're on the list.</p>
						<p class="text-[13px] text-emerald-400/80">We'll email you an invite when your spot opens.</p>
					</div>
				</div>

				<form id="waitlist-form" class="mt-8">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-center">
						<div class="relative flex-1">
							<input
								id="waitlist-email"
								type="email"
								required
								placeholder="you@yourapp.com"
								class="w-full rounded-xl bg-white/[0.07] px-4 py-3 text-[14px] text-white placeholder-zinc-500 ring-1 ring-inset ring-white/15 focus:outline-none focus:ring-amber-400/60 transition"
							/>
						</div>
						<button
							type="submit"
							id="waitlist-submit"
							class="inline-flex items-center justify-center gap-2 rounded-xl bg-white px-5 py-3 text-[14px] font-semibold text-zinc-900 hover:bg-zinc-100 disabled:opacity-70 transition whitespace-nowrap"
						>
							Join the waitlist →
						</button>
					</div>
					{turnstileSiteKey ? <div id="turnstile-widget" class="mt-4" data-sitekey={turnstileSiteKey}></div> : null}
					<p id="waitlist-error" class="mt-3 hidden text-[13px] text-rose-400">
						Something went wrong — try again or email us directly.
					</p>
					<p class="mt-3 text-[12px] text-zinc-600">
						No spam. Unsubscribe any time. Waitlist members get first access and launch pricing.
					</p>
				</form>
			</div>
		</div>
	</div>
</section>

<script define:vars={{ turnstileSiteKey }}>
	const API_URL = 'https://app.deckapp.cloud/api/v1/early-access';
	const form = document.getElementById('waitlist-form');
	const success = document.getElementById('waitlist-success');
	const error = document.getElementById('waitlist-error');
	const emailInput = document.getElementById('waitlist-email');
	const submit = document.getElementById('waitlist-submit');
	let turnstileToken = '';
	let widgetId = null;

	const resetTurnstile = () => {
		if (widgetId !== null && window.turnstile) {
			window.turnstile.reset(widgetId);
			turnstileToken = '';
		}
	};

	const renderTurnstile = () => {
		const container = document.getElementById('turnstile-widget');
		if (!turnstileSiteKey || !container || widgetId !== null || !window.turnstile) {
			return;
		}

		widgetId = window.turnstile.render(container, {
			sitekey: turnstileSiteKey,
			theme: 'dark',
			callback: (token) => {
				turnstileToken = token;
			},
			'expired-callback': () => {
				turnstileToken = '';
			},
			'error-callback': () => {
				turnstileToken = '';
			},
		});
	};

	if (turnstileSiteKey) {
		const interval = window.setInterval(() => {
			if (window.turnstile) {
				window.clearInterval(interval);
				renderTurnstile();
			}
		}, 100);
	}

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		error?.classList.add('hidden');

		if (!emailInput?.value) {
			return;
		}

		if (turnstileSiteKey && !turnstileToken) {
			error?.classList.remove('hidden');
			return;
		}

		submit.disabled = true;
		submit.textContent = 'Joining…';

		try {
			const response = await fetch(API_URL, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
				body: JSON.stringify({
					email: emailInput.value,
					source: 'marketing',
					turnstile_token: turnstileToken || undefined,
				}),
			});

			if (response.ok) {
				form.classList.add('hidden');
				success?.classList.remove('hidden');
				success?.classList.add('flex');
				emailInput.value = '';
				resetTurnstile();
			} else {
				error?.classList.remove('hidden');
				resetTurnstile();
			}
		} catch {
			error?.classList.remove('hidden');
			resetTurnstile();
		} finally {
			submit.disabled = false;
			submit.textContent = 'Join the waitlist →';
		}
	});
</script>
