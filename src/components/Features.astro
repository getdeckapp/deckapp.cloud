---
import Icon from './Icon.astro';

const icons = {
	history:
		'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
	pause: 'M14.25 9v6m-4.5 0V9M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
	search: 'm21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z',
	shield:
		'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
	alert:
		'M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zM12 8.25v4.5m0 3h.008v.008H12v-.008z',
	cloud:
		'M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z',
};

const tintClasses = {
	indigo: 'bg-indigo-50 text-indigo-700 ring-indigo-600/15',
	rose: 'bg-rose-50 text-rose-700 ring-rose-600/15',
	sky: 'bg-sky-50 text-sky-700 ring-sky-600/15',
	violet: 'bg-violet-50 text-violet-700 ring-violet-600/15',
	amber: 'bg-amber-50 text-amber-700 ring-amber-600/15',
	emerald: 'bg-emerald-50 text-emerald-700 ring-emerald-600/15',
};

const features = [
	{
		icon: icons.history,
		tint: 'indigo' as const,
		title: 'Durable execution log',
		body: 'Every queue dispatch lands in your database with start, finish, status, attempt count, and tags. Outlasts Redis retention by months.',
	},
	{
		icon: icons.pause,
		tint: 'rose' as const,
		title: 'Cooperative cancel',
		body: 'Mark a job class Cancellable, drop a checkpoint between steps, and stop runaway work from the dashboard. No SIGTERM, no orphaned writes.',
	},
	{
		icon: icons.search,
		tint: 'sky' as const,
		title: 'Searchable activity',
		body: 'Filter by class, queue, connection, tag, or paste a UUID. The whole window of history is one search bar away, not a Redis dump.',
	},
	{
		icon: icons.shield,
		tint: 'violet' as const,
		title: 'Per-class blocking',
		body: 'Temporarily quiet a noisy job class for 1 hour, 24 hours, or until you say so. Workers pick the block up on the next attempt — no redeploy.',
	},
	{
		icon: icons.alert,
		tint: 'amber' as const,
		title: 'Stale-job alerts',
		body: "Subscribe per class: alert me if SyncInventory hasn't run in 24 hours. Deck checks on schedule and notifies via your existing Laravel channels.",
	},
	{
		icon: icons.cloud,
		tint: 'emerald' as const,
		title: 'Deck Cloud',
		body: 'One hosted dashboard for every project and environment. Every run already tags DECK_PROJECT and DECK_ENVIRONMENT — point at it and you\'re in.',
		pill: 'Early access',
	},
];
---

<section id="features" class="bg-gradient-to-b from-white via-zinc-50/30 to-white py-24">
	<div class="mx-auto max-w-[1100px] px-6">
		<div class="mx-auto max-w-[680px]">
			<p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-indigo-600 mb-3">
				Features
			</p>
			<h2 class="text-[38px] font-semibold tracking-[-0.025em] text-zinc-950 leading-[1.1]">
				Built for the people on call.
			</h2>
			<p class="mt-4 text-[16px] leading-[1.6] text-zinc-600">
				Deck is opinionated about one thing: <span class="text-zinc-900 font-medium">queues need a memory</span>.
				Every feature follows from that.
			</p>
		</div>
		<div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
			{
				features.map((feature) => (
					<div class="group relative overflow-hidden rounded-2xl border border-zinc-200/70 bg-white p-6 shadow-[0_1px_0_rgba(255,255,255,0.7)_inset,0_1px_2px_rgba(15,23,42,0.04)] transition hover:border-zinc-300/80 hover:shadow-[0_1px_0_rgba(255,255,255,0.7)_inset,0_12px_32px_-8px_rgba(15,23,42,0.12)]">
						<div class="flex items-start justify-between gap-3">
							<span
								class={`inline-flex size-10 items-center justify-center rounded-xl ring-1 ring-inset ${tintClasses[feature.tint]}`}
							>
								<Icon d={feature.icon} size={18} strokeWidth={1.75} />
							</span>
							{feature.pill ? (
								<span class="rounded-full bg-zinc-100 px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.10em] text-zinc-600">
									{feature.pill}
								</span>
							) : null}
						</div>
						<h3 class="mt-5 text-[16px] font-semibold tracking-[-0.015em] text-zinc-950">{feature.title}</h3>
						<p class="mt-2 text-[13.5px] leading-[1.6] text-zinc-600">{feature.body}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
