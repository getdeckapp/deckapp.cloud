---
interface Props {
	d: string;
	size?: number;
	class?: string;
	strokeWidth?: number;
}

const { d, size = 16, class: className = '', strokeWidth = 1.75 } = Astro.props;
---

<svg
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width={strokeWidth}
	class={className}
	aria-hidden="true"
>
	<path stroke-linecap="round" stroke-linejoin="round" d={d}></path>
</svg>
