---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Logo from '../components/Logo.astro';
import Features from '../components/Features.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const compareRows = [
	['Worker supervision and balancing', true, false],
	['Recent jobs (short Redis retention)', true, false],
	['Throughput and wait-time metrics', true, false],
	['Per-class last-run and history', false, true],
	['Durable execution log in your database', false, true],
	['Search and filter by class, queue, tag', false, true],
	['Cooperative cancel for opt-in jobs', false, true],
	['Stale-job alerts and long-running flags', false, true],
];
---

<MarketingLayout>
	<header class="sticky top-0 z-40 border-b border-transparent bg-white/80 backdrop-blur-md">
		<div class="mx-auto flex max-w-[1200px] items-center justify-between gap-6 px-6 py-3.5">
			<a href="/" class="flex items-center gap-2.5">
				<Logo />
			</a>
			<nav class="hidden items-center gap-6 text-[13.5px] font-medium text-zinc-600 lg:flex">
				<a href="#features" class="hover:text-zinc-900">Features</a>
				<a href="#compare" class="hover:text-zinc-900">vs Horizon</a>
				<a href="#pricing" class="hover:text-zinc-900">Pricing</a>
				<a href="/overview/" class="hover:text-zinc-900">Docs</a>
			</nav>
			<div class="flex items-center gap-2">
				<a
					href="https://github.com/getdeckapp/deck"
					target="_blank"
					rel="noopener"
					class="rounded-lg px-2.5 py-1.5 text-[13px] font-medium text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900"
				>
					GitHub
				</a>
				<a
					href="#waitlist"
					class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-900 px-3 py-1.5 text-[13px] font-semibold text-white hover:bg-zinc-800"
				>
					Join waitlist →
				</a>
			</div>
		</div>
	</header>

	<section class="relative overflow-hidden">
		<div
			class="absolute inset-0 -z-10"
			style="background-image: radial-gradient(circle, #d4d4d8 1.5px, transparent 1.5px); background-size: 22px 22px; mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 40%, transparent 100%)"
		>
		</div>
		<div
			class="absolute left-1/2 top-0 -z-10 h-[640px] w-[1200px] -translate-x-1/2 opacity-60"
			style="background: radial-gradient(50% 60% at 50% 0%, rgba(245,158,11,0.18) 0%, rgba(245,158,11,0.03) 50%, transparent 80%)"
		>
		</div>
		<div class="mx-auto max-w-[1200px] px-6 pt-16 pb-12 lg:pt-24 lg:pb-16">
			<div class="mx-auto max-w-[820px] text-center">
				<div
					class="mb-6 inline-flex items-center gap-2 rounded-full border border-zinc-200/80 bg-white/70 px-3 py-1 text-[12px] font-medium text-zinc-700 backdrop-blur"
				>
					<span
						class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-2 py-0.5 font-mono text-[10.5px] font-semibold uppercase tracking-[0.10em] text-amber-700 ring-1 ring-inset ring-amber-600/20"
					>
						Deck Cloud
					</span>
					<span class="text-zinc-600">Early access · join the waitlist</span>
				</div>
				<h1 class="font-semibold tracking-[-0.035em] text-zinc-950 text-[52px] leading-[1.02] sm:text-[64px] lg:text-[76px]">
					A job silently<br />
					<span class="bg-gradient-to-br from-amber-600 via-amber-500 to-orange-500 bg-clip-text text-transparent"
						>stopped running.</span
					><br />
					You found out from a customer.
				</h1>
				<p class="mx-auto mt-7 max-w-[560px] text-[17px] leading-[1.6] text-zinc-600">
					Horizon flies the workers. <span class="font-semibold text-zinc-900">Deck</span> runs the operation
					— a durable, searchable log of every dispatch, so next time you know before they do.
				</p>
				<div class="mt-9 flex flex-wrap items-center justify-center gap-3">
					<a
						href="#waitlist"
						class="inline-flex items-center gap-2 rounded-xl bg-zinc-900 px-5 py-3 text-[14px] font-semibold text-white hover:bg-zinc-800"
					>
						Join the waitlist →
					</a>
					<a
						href="/overview/"
						class="inline-flex items-center gap-2 rounded-xl bg-white px-5 py-3 text-[14px] font-semibold text-zinc-900 ring-1 ring-inset ring-zinc-200 hover:bg-zinc-50"
					>
						Documentation
					</a>
				</div>
				<div class="mt-7">
					<code
						class="inline-flex items-center gap-3 rounded-lg border border-zinc-200/80 bg-white/80 px-4 py-2 font-mono text-[12.5px] text-zinc-700 backdrop-blur"
					>
						<span class="text-zinc-400">$</span>
						<span><span class="text-amber-600 font-semibold">composer</span> require deck/deck</span>
					</code>
				</div>
			</div>
		</div>
	</section>

	<Features />

	<section id="compare" class="py-24">
		<div class="mx-auto max-w-[1100px] px-6">
			<div class="mx-auto max-w-[680px] text-center">
				<p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-amber-600 mb-3">
					Side-by-side
				</p>
				<h2 class="text-[38px] font-semibold tracking-[-0.025em] text-zinc-950 leading-[1.1]">
					Keep Horizon. Add Deck.
				</h2>
			</div>
			<div class="mt-14 overflow-hidden rounded-2xl border border-zinc-200/70 bg-white shadow-sm">
				<div class="grid grid-cols-[1fr_130px_130px] border-b border-zinc-100 bg-zinc-50/60 px-5 py-4">
					<div class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.10em] text-zinc-500">
						Capability
					</div>
					<div class="text-center text-[14px] font-semibold text-zinc-900">Horizon</div>
					<div class="text-center text-[14px] font-semibold text-amber-600">Deck</div>
				</div>
				<div class="divide-y divide-zinc-100">
					{
						compareRows.map(([label, horizon, deck]) => (
							<div class="grid grid-cols-[1fr_130px_130px] items-center px-5 py-3.5">
								<p class="text-[13.5px] text-zinc-700">{label}</p>
								<div class="text-center text-emerald-600">{horizon ? '✓' : '—'}</div>
								<div class="text-center text-amber-600">{deck ? '✓' : '—'}</div>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section id="pricing" class="py-24 bg-zinc-50/50">
		<div class="mx-auto max-w-[1100px] px-6 text-center">
			<p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-amber-600 mb-3">
				Pricing
			</p>
			<h2 class="text-[38px] font-semibold tracking-[-0.025em] text-zinc-950">Package is free. Cloud is hosted.</h2>
			<p class="mx-auto mt-4 max-w-[560px] text-[16px] leading-[1.6] text-zinc-600">
				<code class="rounded bg-zinc-100 px-1.5 py-0.5 font-mono text-[13px]">deck/deck</code> is MIT licensed
				and self-hosted. Deck Cloud is a subscription — waitlist members lock in launch pricing.
			</p>
		</div>
	</section>

	<WaitlistForm />

	<footer class="border-t border-zinc-200/60 bg-white py-12">
		<div class="mx-auto max-w-[1100px] px-6">
			<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
				<div>
					<a href="/" class="flex items-center gap-2.5">
						<Logo />
					</a>
					<p class="mt-4 max-w-[280px] text-[13px] leading-[1.6] text-zinc-500">
						Job-class observability and cooperative cancellation for Laravel apps running Horizon.
					</p>
				</div>
				<div>
					<p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Product</p>
					<ul class="mt-3 space-y-2 text-[13px]">
						<li><a href="#features" class="text-zinc-700 hover:text-zinc-900">Features</a></li>
						<li><a href="/overview/" class="text-zinc-700 hover:text-zinc-900">Documentation</a></li>
						<li><a href="#waitlist" class="text-zinc-700 hover:text-zinc-900">Waitlist</a></li>
					</ul>
				</div>
				<div>
					<p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Package docs</p>
					<ul class="mt-3 space-y-2 text-[13px]">
						<li><a href="/package/getting-started/" class="text-zinc-700 hover:text-zinc-900">Getting Started</a></li>
						<li><a href="/package/usage/" class="text-zinc-700 hover:text-zinc-900">Usage</a></li>
					</ul>
				</div>
				<div>
					<p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Resources</p>
					<ul class="mt-3 space-y-2 text-[13px]">
						<li><a href="https://github.com/getdeckapp/deck" class="text-zinc-700 hover:text-zinc-900">GitHub</a></li>
						<li><a href="https://packagist.org/packages/deck/deck" class="text-zinc-700 hover:text-zinc-900">Packagist</a></li>
					</ul>
				</div>
			</div>
			<div class="mt-12 border-t border-zinc-100 pt-6 text-[12px] text-zinc-500">
				© 2026 Deck. MIT licensed. Built by <a href="https://github.com/tormjens" class="text-zinc-700 hover:text-zinc-900">@tormjens</a>.
			</div>
		</div>
	</footer>
</MarketingLayout>
