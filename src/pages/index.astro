---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Logo from '../components/Logo.astro';
import Features from '../components/Features.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const compareRows = [
	['Worker supervision and balancing', true, false],
	['Recent jobs (short Redis retention)', true, false],
	['Throughput and wait-time metrics', true, false],
	['Per-class last-run and history', false, true],
	['Durable execution log in your database', false, true],
	['Search and filter by class, queue, tag', false, true],
	['Cooperative cancel for opt-in jobs', false, true],
	['Stale-job alerts and long-running flags', false, true],
];
---

<MarketingLayout>
	<header class="sticky top-0 z-40 border-b border-transparent bg-white/80 backdrop-blur-md">
		<div class="mx-auto flex max-w-[1200px] items-center justify-between gap-6 px-6 py-3.5">
			<a href="/" class="flex items-center gap-2.5">
				<Logo />
			</a>
			<nav class="hidden items-center gap-6 text-[13.5px] font-medium text-zinc-600 lg:flex">
				<a href="#features" class="hover:text-zinc-900">Features</a>
				<a href="#compare" class="hover:text-zinc-900">vs Horizon</a>
				<a href="#pricing" class="hover:text-zinc-900">Pricing</a>
				<a href="/overview/" class="hover:text-zinc-900">Docs</a>
			</nav>
			<div class="flex items-center gap-2">
				<a
					href="https://github.com/getdeckapp/deck"
					target="_blank"
					rel="noopener"
					class="rounded-lg px-2.5 py-1.5 text-[13px] font-medium text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900"
				>
					GitHub
				</a>
				<a
					href="#waitlist"
					class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-900 px-3 py-1.5 text-[13px] font-semibold text-white hover:bg-zinc-800"
				>
					Get early access →
				</a>
			</div>
		</div>
	</header>

	<section class="relative overflow-hidden">
		<div
			class="absolute inset-0 -z-10"
			style="background-image: radial-gradient(circle, #d4d4d8 1.5px, transparent 1.5px); background-size: 22px 22px; mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 40%, transparent 100%)"
		>
		</div>
		<div
			class="absolute left-1/2 top-0 -z-10 h-[640px] w-[1200px] -translate-x-1/2 opacity-60"
			style="background: radial-gradient(50% 60% at 50% 0%, rgba(245,158,11,0.18) 0%, rgba(245,158,11,0.03) 50%, transparent 80%)"
		>
		</div>
		<div class="mx-auto max-w-[1200px] px-6 pt-16 pb-12 lg:pt-24 lg:pb-16">
			<div class="mx-auto max-w-[820px] text-center">
				<div
					class="mb-6 inline-flex items-center gap-2 rounded-full border border-zinc-200/80 bg-white/70 px-3 py-1 text-[12px] font-medium text-zinc-700 backdrop-blur"
				>
					<span
						class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-2 py-0.5 font-mono text-[10.5px] font-semibold uppercase tracking-[0.10em] text-amber-700 ring-1 ring-inset ring-amber-600/20"
					>
						Deck Cloud
					</span>
					<span class="text-zinc-600">Early access open</span>
				</div>
				<h1 class="font-semibold tracking-[-0.035em] text-zinc-950 text-[52px] leading-[1.02] sm:text-[64px] lg:text-[76px]">
					A job silently<br />
					<span class="bg-gradient-to-br from-amber-600 via-amber-500 to-orange-500 bg-clip-text text-transparent"
						>stopped running.</span
					><br />
					You found out from a customer.
				</h1>
				<p class="mx-auto mt-7 max-w-[560px] text-[17px] leading-[1.6] text-zinc-600">
					Horizon flies the workers. <span class="font-semibold text-zinc-900">Deck</span> runs the operation
					— a durable, searchable log of every dispatch, so next time you know before they do.
				</p>
				<div class="mt-9 flex flex-wrap items-center justify-center gap-3">
					<a
						href="#waitlist"
						class="inline-flex items-center gap-2 rounded-xl bg-zinc-900 px-5 py-3 text-[14px] font-semibold text-white hover:bg-zinc-800"
					>
						Get early access →
					</a>
					<a
						href="/overview/"
						class="inline-flex items-center gap-2 rounded-xl bg-white px-5 py-3 text-[14px] font-semibold text-zinc-900 ring-1 ring-inset ring-zinc-200 hover:bg-zinc-50"
					>
						Documentation
					</a>
				</div>
				<div class="mt-7">
					<code
						class="inline-flex items-center gap-3 rounded-lg border border-zinc-200/80 bg-white/80 px-4 py-2 font-mono text-[12.5px] text-zinc-700 backdrop-blur"
					>
						<span class="text-zinc-400">$</span>
						<span><span class="text-amber-600 font-semibold">composer</span> require deck/deck</span>
					</code>
				</div>
			</div>
		</div>
	</section>

	<Features />

	<section id="compare" class="py-24">
		<div class="mx-auto max-w-[1100px] px-6">
			<div class="mx-auto max-w-[680px] text-center">
				<p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-amber-600 mb-3">
					Side-by-side
				</p>
				<h2 class="text-[38px] font-semibold tracking-[-0.025em] text-zinc-950 leading-[1.1]">
					Keep Horizon. Add Deck.
				</h2>
			</div>
			<div class="mt-14 overflow-hidden rounded-2xl border border-zinc-200/70 bg-white shadow-sm">
				<div class="grid grid-cols-[1fr_130px_130px] border-b border-zinc-100 bg-zinc-50/60 px-5 py-4">
					<div class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.10em] text-zinc-500">
						Capability
					</div>
					<div class="text-center text-[14px] font-semibold text-zinc-900">Horizon</div>
					<div class="text-center text-[14px] font-semibold text-amber-600">Deck</div>
				</div>
				<div class="divide-y divide-zinc-100">
					{
						compareRows.map(([label, horizon, deck]) => (
							<div class="grid grid-cols-[1fr_130px_130px] items-center px-5 py-3.5">
								<p class="text-[13.5px] text-zinc-700">{label}</p>
								<div class="text-center text-emerald-600">{horizon ? '✓' : '—'}</div>
								<div class="text-center text-amber-600">{deck ? '✓' : '—'}</div>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section id="pricing" class="relative py-24 bg-gradient-to-b from-zinc-50/40 to-white">
		<div class="mx-auto max-w-[1100px] px-6">
			<div class="mx-auto max-w-[680px] text-center">
				<p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-amber-600 mb-3">Pricing</p>
				<h2 class="text-[38px] font-semibold tracking-[-0.025em] text-zinc-950 leading-[1.1]">Free where it runs. Paid where it scales.</h2>
				<p class="mt-4 text-[16px] leading-[1.6] text-zinc-600">
					The package is and always will be MIT. Deck Cloud is for teams who want one pane of glass across many apps.
				</p>
			</div>
			<div class="mt-14 grid gap-5 lg:grid-cols-3">

				<!-- Self-hosted -->
				<div class="relative overflow-hidden rounded-2xl p-7 border border-zinc-200/70 bg-white shadow-[0_1px_0_rgba(255,255,255,0.7)_inset,0_1px_2px_rgba(15,23,42,0.04)]">
					<div class="flex items-center gap-2">
						<h3 class="text-[16px] font-semibold tracking-[-0.015em] text-zinc-950">Self-hosted</h3>
						<span class="inline-flex items-center rounded-full px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.10em] bg-zinc-100 text-zinc-600 ring-1 ring-inset ring-zinc-200">Open source</span>
					</div>
					<div class="mt-5 flex items-baseline gap-2">
						<span class="text-[40px] font-semibold tabular-nums tracking-[-0.025em] text-zinc-950 leading-none">$0</span>
						<span class="font-mono text-[12px] text-zinc-500">forever</span>
					</div>
					<p class="mt-3 text-[13.5px] leading-[1.55] text-zinc-600">The MIT-licensed Composer package. Runs in your Laravel app, stores in your database.</p>
					<a href="https://github.com/getdeckapp/deck" class="mt-6 flex items-center justify-center gap-2 rounded-xl px-4 py-2.5 text-[13.5px] font-semibold transition bg-white text-zinc-900 ring-1 ring-inset ring-zinc-200 hover:bg-zinc-50">
						<code class="font-mono">composer require</code>
						<span class="opacity-60">→</span>
					</a>
					<ul class="mt-7 space-y-2.5 text-[13px]">
						{["Full dashboard at /deck", "Durable execution log in your DB", "Cooperative cancel + retry", "Stale-job alerts via your channels", "Block / unblock job classes", "Tagged for Deck Cloud"].map((f) => (
							<li class="flex items-start gap-2.5 text-zinc-700">
								<span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center rounded bg-zinc-100 text-zinc-600">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-2.5"><polyline points="20 6 9 17 4 12"/></svg>
								</span>
								<span>{f}</span>
							</li>
						))}
					</ul>
				</div>

				<!-- Cloud Team (featured) -->
				<div class="relative overflow-hidden rounded-2xl p-7 shadow-[0_1px_0_rgba(255,255,255,0.7)_inset,0_24px_48px_-12px_rgba(217,119,6,0.18)] ring-1 ring-inset ring-amber-300/40 bg-gradient-to-b from-white via-white to-amber-50/30">
					<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-amber-400 to-transparent"></div>
					<div class="flex items-center gap-2">
						<h3 class="text-[16px] font-semibold tracking-[-0.015em] text-zinc-950">Cloud Team</h3>
						<span class="inline-flex items-center rounded-full px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.10em] bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20">Deck Cloud</span>
					</div>
					<div class="mt-5 flex items-baseline gap-2">
						<span class="text-[40px] font-semibold tabular-nums tracking-[-0.025em] text-zinc-950 leading-none">$29</span>
						<span class="font-mono text-[12px] text-zinc-500">per team / month</span>
					</div>
					<p class="mt-2 inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-2.5 py-1 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-amber-700 ring-1 ring-inset ring-amber-600/20">
						7-day free trial
					</p>
					<p class="mt-3 text-[13.5px] leading-[1.55] text-zinc-600">One hosted dashboard for your whole team — unlimited projects and environments included.</p>
					<a href="#waitlist" class="mt-6 flex items-center justify-center gap-2 rounded-xl px-4 py-2.5 text-[13.5px] font-semibold transition bg-zinc-900 text-white shadow-[0_1px_0_rgba(255,255,255,0.18)_inset,0_4px_12px_-2px_rgba(217,119,6,0.30)] hover:bg-zinc-800">
						Get early access
						<span class="opacity-60">→</span>
					</a>
					<ul class="mt-7 space-y-2.5 text-[13px]">
						{[
							"Unlimited projects & environments",
							"Shared incident history",
							"Slack + email notifications",
							"Team roles & SSO (Google, GitHub)",
							"30-day execution retention",
						].map((f) => (
							<li class="flex items-start gap-2.5 text-zinc-700">
								<span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center rounded bg-amber-100 text-amber-700">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-2.5"><polyline points="20 6 9 17 4 12"/></svg>
								</span>
								<span>{f}</span>
							</li>
						))}
						<li class="flex items-start gap-2.5 text-zinc-700">
							<span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center rounded bg-amber-100 text-amber-700">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-2.5"><polyline points="20 6 9 17 4 12"/></svg>
							</span>
							<span>
								Up to 10M executions / month
								<span class="block mt-0.5 font-mono text-[11px] text-zinc-400">Most teams use 1–3M / month.</span>
							</span>
						</li>
						<li class="flex items-start gap-2.5 text-zinc-700">
							<span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center rounded bg-amber-100 text-amber-700">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-2.5"><polyline points="20 6 9 17 4 12"/></svg>
							</span>
							<span>Email support</span>
						</li>
					</ul>
					<p class="mt-4 text-[11.5px] text-zinc-500 font-mono">Additional executions $1 per million.</p>
				</div>

				<!-- Cloud Enterprise -->
				<div class="relative overflow-hidden rounded-2xl p-7 border border-zinc-200/70 bg-white shadow-[0_1px_0_rgba(255,255,255,0.7)_inset,0_1px_2px_rgba(15,23,42,0.04)]">
					<div class="flex items-center gap-2">
						<h3 class="text-[16px] font-semibold tracking-[-0.015em] text-zinc-950">Cloud Enterprise</h3>
						<span class="inline-flex items-center rounded-full px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.10em] bg-zinc-100 text-zinc-600 ring-1 ring-inset ring-zinc-200">Deck Cloud</span>
					</div>
					<div class="mt-5 flex items-baseline gap-2">
						<span class="text-[40px] font-semibold tabular-nums tracking-[-0.025em] text-zinc-950 leading-none">Custom</span>
						<span class="font-mono text-[12px] text-zinc-500">annual</span>
					</div>
					<p class="mt-3 text-[13.5px] leading-[1.55] text-zinc-600">For teams running high-volume production fleets. Audit logs, extended retention, deployment options.</p>
					<a href="#waitlist" class="mt-6 flex items-center justify-center gap-2 rounded-xl px-4 py-2.5 text-[13.5px] font-semibold transition bg-white text-zinc-900 ring-1 ring-inset ring-zinc-200 hover:bg-zinc-50">
						Talk to us
						<span class="opacity-60">→</span>
					</a>
					<ul class="mt-7 space-y-2.5 text-[13px]">
						{["Everything in Team", "SAML SSO + SCIM", "Audit logs & access controls", "1-year execution retention", "High-volume execution limits", "Self-hosted Cloud option", "Priority support + uptime SLA"].map((f) => (
							<li class="flex items-start gap-2.5 text-zinc-700">
								<span class="mt-0.5 inline-flex size-4 shrink-0 items-center justify-center rounded bg-zinc-100 text-zinc-600">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-2.5"><polyline points="20 6 9 17 4 12"/></svg>
								</span>
								<span>{f}</span>
							</li>
						))}
					</ul>
				</div>

			</div>
			<p class="mt-10 text-center text-[12.5px] text-zinc-500">
				Every Cloud Team plan starts with a <span class="font-mono font-semibold text-zinc-700">7-day free trial</span> — no charge until it ends.
				Deck Cloud is in <span class="font-mono font-semibold text-zinc-700">early access</span>;
				pricing may shift before general availability — early access members get notice first.
			</p>
		</div>
	</section>

	<WaitlistForm />

	<footer class="border-t border-zinc-200/60 bg-white py-12">
		<div class="mx-auto max-w-[1100px] px-6">
			<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
				<div>
					<a href="/" class="flex items-center gap-2.5">
						<Logo />
					</a>
					<p class="mt-4 max-w-[280px] text-[13px] leading-[1.6] text-zinc-500">
						Job-class observability and cooperative cancellation for Laravel apps running Horizon.
					</p>
				</div>
				<div>
					<p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Product</p>
					<ul class="mt-3 space-y-2 text-[13px]">
						<li><a href="#features" class="text-zinc-700 hover:text-zinc-900">Features</a></li>
						<li><a href="/overview/" class="text-zinc-700 hover:text-zinc-900">Documentation</a></li>
						<li><a href="#waitlist" class="text-zinc-700 hover:text-zinc-900">Early access</a></li>
					</ul>
				</div>
				<div>
					<p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Package docs</p>
					<ul class="mt-3 space-y-2 text-[13px]">
						<li><a href="/package/getting-started/" class="text-zinc-700 hover:text-zinc-900">Getting Started</a></li>
						<li><a href="/package/usage/" class="text-zinc-700 hover:text-zinc-900">Usage</a></li>
					</ul>
				</div>
				<div>
					<p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Resources</p>
					<ul class="mt-3 space-y-2 text-[13px]">
						<li><a href="https://github.com/getdeckapp/deck" class="text-zinc-700 hover:text-zinc-900">GitHub</a></li>
						<li><a href="https://packagist.org/packages/deck/deck" class="text-zinc-700 hover:text-zinc-900">Packagist</a></li>
					</ul>
				</div>
			</div>
			<div class="mt-12 border-t border-zinc-100 pt-6 text-[12px] text-zinc-500">
				© 2026 Deck. MIT licensed. Built by <a href="https://github.com/tormjens" class="text-zinc-700 hover:text-zinc-900">@tormjens</a>.
			</div>
		</div>
	</footer>
</MarketingLayout>
